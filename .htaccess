Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule "(^|/)\.(?!well-known/)" - [F,L]
  RewriteRule "^(server|src|scripts|deploy|node_modules|database)(/|$)" - [F,L,NC]
  RewriteRule "^(package(-lock)?\.json|vite\.config\.js|ecosystem\.config\.cjs|app\.js|README\.md)$" - [F,L,NC]

  RewriteRule ^api/install$ - [F,L,NC]
  RewriteRule ^setup\.html$ - [F,L,NC]
  RewriteRule ^api(?:/.*)?$ api/index.php [QSA,L]
  RewriteRule ^public/ - [L]
  RewriteRule ^$ public/index.html [L]
  RewriteRule . public/index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline';
  img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors
  'self';"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>